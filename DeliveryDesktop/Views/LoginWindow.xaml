<Window x:Class="DeliveryDesktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система доставки — Вход" Height="400" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
  <StackPanel Margin="40" VerticalAlignment="Center">
    <TextBlock Text="Система управления доставкой"
               FontSize="15" FontWeight="Bold"
               HorizontalAlignment="Center" Margin="0,0,0,5"/>
    <TextBlock Text="Вариант 18" FontSize="11" Foreground="Gray"
               HorizontalAlignment="Center" Margin="0,0,0,25"/>

    <TextBlock Text="Логин:" Margin="0,0,0,4"/>
    <TextBox x:Name="UsernameBox" Height="30" Margin="0,0,0,12" Padding="6,4"/>

    <TextBlock Text="Пароль:" Margin="0,0,0,4"/>
    <PasswordBox x:Name="PasswordBox" Height="30" Margin="0,0,0,12" Padding="6,4"/>

    <TextBlock x:Name="ErrorText" Foreground="Red"
               Margin="0,0,0,10" FontSize="12"/>

    <Button Content="Войти" Height="34" FontSize="13"
            Click="LoginButton_Click"/>

    <TextBlock Text="user / user123  —  обычный пользователь"
               FontSize="10" Foreground="Gray" Margin="0,20,0,2"
               HorizontalAlignment="Center"/>
    <TextBlock Text="admin / admin123  —  администратор"
               FontSize="10" Foreground="Gray"
               HorizontalAlignment="Center"/>
  </StackPanel>
</Window>