<Window x:Class="DeliveryDesktop.Views.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Служба доставки — Пользователь" Height="500" Width="750"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#3C6E71" Padding="12,8">
            <TextBlock Text="Служба доставки — Управление посылками"
                       FontSize="15" FontWeight="Bold" Foreground="White"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#F0F0F0"
                BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="8,5">
            <TextBlock x:Name="LogText" FontSize="11"
                       Foreground="#555555" FontFamily="Consolas"/>
        </Border>

        <!-- Поиск по трек-номеру -->
        <Border DockPanel.Dock="Top" Padding="12,10"
                BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Поиск посылки по трек-номеру:"
                           FontWeight="Bold" Margin="0,0,0,8"/>
                <WrapPanel>
                    <TextBox x:Name="SearchBox" Width="200" Height="26"
                             Padding="4,3" Margin="0,0,10,0"/>
                    <Button Content="Найти" Height="26" Padding="12,0"
                            Click="SearchPackage_Click" Margin="0,0,20,0"/>
                    <TextBlock Text="|" Foreground="#CCCCCC"
                               VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock Text="Создать новую посылку:"
                               FontWeight="Bold" VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Вес (кг)" FontSize="11" Margin="0,0,0,2"/>
                            <TextBox x:Name="WeightBox" Width="80" Height="26" Padding="4,3"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="ID клиента" FontSize="11" Margin="0,0,0,2"/>
                            <TextBox x:Name="ClientIdBox" Width="80" Height="26" Padding="4,3"/>
                        </StackPanel>
                        <Button Content="Создать" Height="26" Padding="12,0"
                                VerticalAlignment="Bottom" Click="CreatePackage_Click"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Результат поиска -->
        <Border Padding="12">
            <StackPanel>
                <TextBlock x:Name="SearchResultTitle" Text=""
                           FontWeight="Bold" Margin="0,0,0,8" FontSize="13"/>
                <Grid x:Name="PackageInfoGrid" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Трек-номер:" FontWeight="Bold" Margin="0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InfoTracking" Margin="0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Статус:" FontWeight="Bold" Margin="0,4"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="InfoStatus" Margin="0,4" FontSize="14"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Вес:" FontWeight="Bold" Margin="0,4"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="InfoWeight" Margin="0,4"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Клиент:" FontWeight="Bold" Margin="0,4"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="InfoClient" Margin="0,4"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Курьер:" FontWeight="Bold" Margin="0,4"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="InfoCourier" Margin="0,4"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Маршрут:" FontWeight="Bold" Margin="0,4"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="InfoRoute" Margin="0,4"/>
                </Grid>
            </StackPanel>
        </Border>
    </DockPanel>
</Window>