<Window x:Class="DeliveryDesktop.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Служба доставки — Администратор" Height="700" Width="1050"
        WindowStartupLocation="CenterScreen">
    <DockPanel>

        <!-- Заголовок -->
        <Border DockPanel.Dock="Top" Background="#284B63" Padding="12,8">
            <TextBlock Text="Служба доставки — Администратор"
                 FontSize="15" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Лог внизу -->
        <Border DockPanel.Dock="Bottom" Background="#F0F0F0"
            BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="8,5">
            <TextBlock x:Name="AdminLogText" FontSize="11"
                 Foreground="#555555" FontFamily="Consolas"/>
        </Border>

        <!-- Вкладки -->
        <TabControl Margin="5">

            <!-- ═══════════════ ПОСЫЛКИ ═══════════════ -->
            <TabItem Header="Посылки">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,6" Background="#F8F8F8">
                        <Button Content="Обновить" Padding="10,4" Margin="4" Click="RefreshPackages_Click"/>
                        <Separator Width="1" Background="#CCCCCC" Margin="4,2"/>
                        <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="4,0" FontWeight="Bold"/>
                        <Button Content="◀ Предыдущий" Padding="10,4" Margin="4" Click="PrevStatus_Click"/>
                        <Button Content="Следующий ▶" Padding="10,4" Margin="4" Click="NextStatus_Click"/>
                        <Separator Width="1" Background="#CCCCCC" Margin="4,2"/>
                        <Button Content="Сменить маршрут" Padding="10,4" Margin="4" Click="ChangeRoute_Click"/>
                        <Separator Width="1" Background="#CCCCCC" Margin="4,2"/>
                        <Button Content="Удалить" Padding="10,4" Margin="4" Background="#F38BA8" Click="DeletePackage_Click"/>
                    </StackPanel>

                    <Border DockPanel.Dock="Top" Background="#EEF4FF" Padding="8,4"
                  BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                        <TextBlock x:Name="PackageHint" Text="Выберите посылку в таблице"
                       Foreground="#555555" FontSize="11"/>
                    </Border>

                    <DataGrid x:Name="AdminPackagesGrid" Margin="8,4,8,8"
                    AutoGenerateColumns="False" IsReadOnly="True"
                    GridLinesVisibility="Horizontal" RowHeaderWidth="0"
                    SelectionChanged="AdminPackagesGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
                            <DataGridTextColumn Header="Трек-номер" Binding="{Binding TrackingNumber}" Width="150"/>
                            <DataGridTextColumn Header="Вес (кг)" Binding="{Binding WeightKg}" Width="70"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding StatusRu}" Width="110"/>
                            <DataGridTextColumn Header="Клиент ID" Binding="{Binding ClientId}" Width="80"/>
                            <DataGridTextColumn Header="Маршрут" Binding="{Binding Route.Name}" Width="*"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ═══════════════ КЛИЕНТЫ ═══════════════ -->
            <TabItem Header="Клиенты">
                <DockPanel>

                    <!-- Форма добавления -->
                    <Border DockPanel.Dock="Top" Padding="10,8"
                  BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Background="#FAFAFA">
                        <StackPanel>
                            <TextBlock Text="Добавить клиента:" FontWeight="Bold" Margin="0,0,0,6"/>
                            <WrapPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Имя" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="ClientNameBox" Width="150" Height="26" Padding="4,3"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Телефон" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="ClientPhoneBox" Width="120" Height="26" Padding="4,3"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Email" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="ClientEmailBox" Width="150" Height="26" Padding="4,3"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Адрес" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="ClientAddressBox" Width="180" Height="26" Padding="4,3"/>
                                </StackPanel>
                                <Button Content="Добавить" Height="26" Padding="12,0"
                        VerticalAlignment="Bottom" Click="AddClient_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки управления -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,4">
                        <Button Content="Обновить" Padding="10,4" Margin="0,0,8,0" Click="RefreshClients_Click"/>
                        <Button Content="Удалить выбранного" Padding="10,4"
                    Background="#F38BA8" Click="DeleteClient_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="ClientsGrid" Margin="8,0,8,8"
                    AutoGenerateColumns="False" IsReadOnly="True"
                    GridLinesVisibility="Horizontal" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ═══════════════ КУРЬЕРЫ ═══════════════ -->
            <TabItem Header="Курьеры">
                <DockPanel>

                    <!-- Форма добавления -->
                    <Border DockPanel.Dock="Top" Padding="10,8"
                  BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Background="#FAFAFA">
                        <StackPanel>
                            <TextBlock Text="Добавить курьера:" FontWeight="Bold" Margin="0,0,0,6"/>
                            <WrapPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Имя" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="CourierNameBox" Width="150" Height="26" Padding="4,3"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Телефон" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="CourierPhoneBox" Width="120" Height="26" Padding="4,3"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Транспорт" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="CourierVehicleBox" Width="120" Height="26" Padding="4,3"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Доступен" FontSize="11" Margin="0,0,0,2"/>
                                    <CheckBox x:Name="CourierAvailableBox" IsChecked="True"
                            VerticalAlignment="Center" Height="26"/>
                                </StackPanel>
                                <Button Content="Добавить" Height="26" Padding="12,0"
                        VerticalAlignment="Bottom" Click="AddCourier_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки управления -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,4">
                        <Button Content="Обновить" Padding="10,4" Margin="0,0,8,0" Click="RefreshCouriers_Click"/>
                        <Button Content="Удалить выбранного" Padding="10,4"
                    Background="#F38BA8" Click="DeleteCourier_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="CouriersGrid" Margin="8,0,8,8"
                    AutoGenerateColumns="False" IsReadOnly="True"
                    GridLinesVisibility="Horizontal" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
                            <DataGridTextColumn Header="Транспорт" Binding="{Binding Vehicle}" Width="120"/>
                            <DataGridCheckBoxColumn Header="Доступен" Binding="{Binding IsAvailable}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ═══════════════ МАРШРУТЫ ═══════════════ -->
            <TabItem Header="Маршруты">
                <DockPanel>

                    <!-- Форма добавления -->
                    <Border DockPanel.Dock="Top" Padding="10,8"
                  BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Background="#FAFAFA">
                        <StackPanel>
                            <TextBlock Text="Добавить маршрут:" FontWeight="Bold" Margin="0,0,0,6"/>
                            <WrapPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Название" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="RouteNameBox" Width="120" Height="26" Padding="4,3"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Откуда (склад)" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="RouteStartBox" Width="150" Height="26" Padding="4,3"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Куда (район)" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="RouteEndBox" Width="150" Height="26" Padding="4,3"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Расстояние (км)" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="RouteDistanceBox" Width="100" Height="26" Padding="4,3"/>
                                </StackPanel>
                                <Button Content="Добавить" Height="26" Padding="12,0"
                        VerticalAlignment="Bottom" Click="AddRoute_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки управления -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,4">
                        <Button Content="Обновить" Padding="10,4" Margin="0,0,8,0" Click="RefreshRoutes_Click"/>
                        <Button Content="Удалить выбранный" Padding="10,4"
                    Background="#F38BA8" Click="DeleteRoute_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="RoutesGrid" Margin="8,0,8,8"
                    AutoGenerateColumns="False" IsReadOnly="True"
                    GridLinesVisibility="Horizontal" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Откуда" Binding="{Binding StartPoint}" Width="*"/>
                            <DataGridTextColumn Header="Куда" Binding="{Binding EndPoint}" Width="*"/>
                            <DataGridTextColumn Header="Км" Binding="{Binding DistanceKm}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
