<Window x:Class="DeliveryDesktop.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Служба доставки — Администратор" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">
  <DockPanel>
    <!-- Заголовок -->
    <Border DockPanel.Dock="Top" Background="#284B63" Padding="12,8">
      <TextBlock Text="Служба доставки — Администратор"
                 FontSize="15" FontWeight="Bold" Foreground="White"/>
    </Border>

    <!-- Лог внизу -->
    <Border DockPanel.Dock="Bottom" Background="#F0F0F0"
            BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="8,5">
      <TextBlock x:Name="AdminLogText" FontSize="11"
                 Foreground="#555555" FontFamily="Consolas"/>
    </Border>

    <!-- Вкладки -->
    <TabControl Margin="5">

      <!-- Посылки -->
      <TabItem Header="Посылки">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <Button Content="Обновить" Padding="10,4" Margin="0,0,8,0"
                    Click="RefreshPackages_Click"/>
            <Button Content="Удалить выбранное" Padding="10,4" Margin="0,0,8,0"
                    Click="DeletePackage_Click"/>
            <Button Content="Следующий статус" Padding="10,4"
                    Click="UpdateStatus_Click"/>
          </StackPanel>
          <DataGrid x:Name="AdminPackagesGrid" Margin="8,0,8,8"
                    AutoGenerateColumns="False" IsReadOnly="True"
                    GridLinesVisibility="Horizontal" RowHeaderWidth="0">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
              <DataGridTextColumn Header="Трек-номер" Binding="{Binding TrackingNumber}" Width="120"/>
              <DataGridTextColumn Header="Вес" Binding="{Binding WeightKg}" Width="65"/>
              <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
              <DataGridTextColumn Header="Клиент ID" Binding="{Binding ClientId}" Width="75"/>
              <DataGridTextColumn Header="Курьер ID" Binding="{Binding CourierId}" Width="75"/>
              <DataGridTextColumn Header="Маршрут ID" Binding="{Binding RouteId}" Width="85"/>
              <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </TabItem>

      <!-- Клиенты -->
      <TabItem Header="Клиенты">
        <DockPanel>
          <Button DockPanel.Dock="Top" Content="Обновить"
                  Padding="10,4" Margin="8" HorizontalAlignment="Left"
                  Click="RefreshClients_Click"/>
          <DataGrid x:Name="ClientsGrid" Margin="8,0,8,8"
                    AutoGenerateColumns="False" IsReadOnly="True"
                    GridLinesVisibility="Horizontal" RowHeaderWidth="0">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
              <DataGridTextColumn Header="Имя" Binding="{Binding FullName}" Width="*"/>
              <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
              <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
              <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </TabItem>

      <!-- Курьеры -->
      <TabItem Header="Курьеры">
        <DockPanel>
          <Button DockPanel.Dock="Top" Content="Обновить"
                  Padding="10,4" Margin="8" HorizontalAlignment="Left"
                  Click="RefreshCouriers_Click"/>
          <DataGrid x:Name="CouriersGrid" Margin="8,0,8,8"
                    AutoGenerateColumns="False" IsReadOnly="True"
                    GridLinesVisibility="Horizontal" RowHeaderWidth="0">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
              <DataGridTextColumn Header="Имя" Binding="{Binding FullName}" Width="*"/>
              <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
              <DataGridTextColumn Header="Транспорт" Binding="{Binding Vehicle}" Width="120"/>
              <DataGridCheckBoxColumn Header="Доступен" Binding="{Binding IsAvailable}" Width="80"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </TabItem>

      <!-- Маршруты -->
      <TabItem Header="Маршруты">
        <DockPanel>
          <Button DockPanel.Dock="Top" Content="Обновить"
                  Padding="10,4" Margin="8" HorizontalAlignment="Left"
                  Click="RefreshRoutes_Click"/>
          <DataGrid x:Name="RoutesGrid" Margin="8,0,8,8"
                    AutoGenerateColumns="False" IsReadOnly="True"
                    GridLinesVisibility="Horizontal" RowHeaderWidth="0">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
              <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
              <DataGridTextColumn Header="Откуда" Binding="{Binding StartPoint}" Width="*"/>
              <DataGridTextColumn Header="Куда" Binding="{Binding EndPoint}" Width="*"/>
              <DataGridTextColumn Header="Км" Binding="{Binding DistanceKm}" Width="80"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </TabItem>

    </TabControl>
  </DockPanel>
</Window>